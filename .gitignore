# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# Environment and tooling
.python-version

# Distribution / packaging
build/
dist/
*.egg-info/

# Logs and temp files
*.log
*.tmp
*.swp

# IDE / editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# ---- data layout ----
# Ignore everything under data/ by default ...
data/*
# ... but keep the canonical runs/ index so manifests and READMEs are
# tracked in git while the heavy MP4/IMU payloads are distributed via
# GitHub Releases (see scripts/datasets/pull.sh).
!data/runs/
data/runs/*
!data/runs/*/
data/runs/*/*
!data/runs/*/README.md
!data/runs/*/manifest.csv
!data/runs/*/.gitkeep

# data_workspace/ is derivable from data/runs/ via 00_process_videos.py
data_workspace/

*.MP4
*.mp4
.env
debug_data/*
.workflow/*

*.tar.gz